PORT=3000

# Database engine: set to 'mysql' to use MySQL, omit or set to anything else for in-memory
# DB_ENGINE=mysql

# MySQL connection (required when DB_ENGINE=mysql)
DB_HOST=db
DB_PORT=3306
DB_NAME=apex_nevada
DB_USER=root
DB_PASSWORD=secret

# ── Test environment (.env.test) ──────────────────────────────────────────────
# Copy the block below into .env.test before running `npm run test:cucumber`.
# The test database (apex_nevada_test) must exist and be reachable before tests run.
#
# DB_ENGINE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=apex_nevada_test
# DB_USER=root
# DB_PASSWORD=secret
# PORT=3099
